// ////////////////////////////////////////////////////////////////
// // SOC Address Map
// // This file contains the address map for the SOC.
// // It is used to generate the address map for the SOC.

`include "../../../third_party/caliptra-rtl/src/soc_ifc/rtl/soc_ifc_doc.rdl"
`include "../../../third_party/caliptra-rtl/src/soc_ifc/rtl/mbox_csr.rdl" 
`include "../../../src/mci/rtl/mci_top.rdl"
`include "../../../third_party/caliptra-rtl/src/soc_ifc/rtl/sha512_acc_csr.rdl"
`include "../../../third_party/i3c-core/src/rdl/registers.rdl"
`include "../../../src/fuse_ctrl/rtl/otp_ctrl.rdl"
`include "../../../src/lc_ctrl/rtl/lc_ctrl.rdl"
`include "../../../third_party/usb2/systemrdl/usbhsd.rdl"
`include "../../../third_party/usb2/systemrdl/usbhsh.rdl"
`include "../../../third_party/usb2/systemrdl/usb_ocp_recovery_reg.rdl"

addrmap soc {

    usbhsd usbhsd @ 0x2000_0000;

    usbhsh usbhsh @ 0x2000_1000;

    // OCP Recovery v1.1 register file exposed by the USB device subsystem
    // (third_party/usb2).  Reached via the existing dev_axi tap into the
    // recovery rb_* reg-bus; consumed by Caliptra firmware as
    // SS_RECOVERY_IFC_BASE_ADDR per OCP Recovery v1.1 Sec 8.5 / 9.2 and the
    // streaming-boot handoff pattern (cptra_test_rom_streaming_boot.c).
    // Lives in the free hole between usbhsh@0x2000_1000 and
    // I3CCSR@0x2000_4000 per plan.md D0.B and rtl_review.md Section H.
    usb_ocp_recovery_reg usb_ocp_recovery_reg @ 0x2000_2000;

    I3CCSR I3CCSR @ 0x2000_4000;

    mci_top mci_top @ 0x2100_0000;
    
    mbox_csr mbox_csr @ 0xa002_0000;

    sha512_acc_csr sha512_acc_csr @ 0xa002_1000;

    soc_ifc_reg soc_ifc_reg @ 0xa003_0000;

    otp_ctrl otp_ctrl @ 0x7000_0000;

    lc_ctrl lc_ctrl @ 0x7000_0400;
};
