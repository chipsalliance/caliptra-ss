+  assign wr_req.awlen   = req.aw.len;                                 \
+  assign wr_req.awsize  = req.aw.size;                                \
+  assign wr_req.awburst = req.aw.burst;                               \
+  assign wr_req.awlock  = req.aw.lock;                                \
+  assign wr_req.awuser  = req.aw.user;                                \
