{
  name: "lowrisc_uart",
  target_dir: "rtl",
  patch_dir: "patch",

  upstream: {
    url: "https://github.com/lowRISC/opentitan.git",
    rev: "earlgrey_1.0.0",
  },

  mapping: [
    {
      from:      "hw/ip/uart/rtl",
      to:        ".",
      patch_dir: "."
    }
  ]
}
